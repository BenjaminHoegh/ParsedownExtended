{
  "name": "benjaminhoegh/parsedown-extended",
  "description": "An extension for Parsedown.",
  "keywords": [
    "markdown",
    "markdown extended",
    "parsedown",
    "parsedown extended"
  ],
  "homepage": "https://github.com/benjaminhoegh/parsedown-extended",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Benjamin Hoegh",
      "homepage": "https://github.com/benjaminhoegh"
    }
  ],
  "require": {
    "erusev/parsedown": "^2.0.0-beta-1",
    "php": "^7.4 || ^8.0",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "friendsofphp/php-cs-fixer": "^3.64",
    "squizlabs/php_codesniffer": "^3.7",
    "phpcompatibility/php-compatibility": "^9.3"
  },
  "autoload": {
    "psr-4": {
      "BenjaminHoegh\\ParsedownExtended\\": "src/"
    }
  },
  "scripts": {
    "check-php-compatibility": "phpcs -p --standard=phpcs.xml",
    "post-install-cmd": [
      "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility"
    ],
    "post-update-cmd": [
      "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility"
    ]
  }
}

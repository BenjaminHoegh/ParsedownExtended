{
  "name": "benjaminhoegh/parsedown-extended",
  "description": "An extension for Parsedown.",
  "keywords": [
    "markdown",
    "markdown extended",
    "parsedown",
    "parsedown extended"
  ],
  "homepage": "https://github.com/benjaminhoegh/parsedown-extended",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Benjamin Hoegh",
      "homepage": "https://github.com/benjaminhoegh"
    }
  ],
  "require": {
    "php": ">=7.4",
    "erusev/parsedown": "^1.8.0",
    "erusev/parsedown-extra": "^0.9.0",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "friendsofphp/php-cs-fixer": "^3.64",
    "vimeo/psalm": "^6.16"
  },
  "autoload": {
    "psr-4": {
      "BenjaminHoegh\\ParsedownExtended\\": "src/"
    }
  },
  "scripts": {
    "benchmark": "php benchmarks/benchmark.php",
    "docs:configuration": "php bin/generate-configuration-docs.php",
    "docs:check": "php bin/generate-configuration-docs.php --check"
  }
}
